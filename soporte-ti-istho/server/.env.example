NODE_ENV=development
PORT=5000

# ── MySQL (desarrollo) ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=soporte_ti_istho
DB_USER=root
DB_PASSWORD=

# ── MySQL (producción Railway) ─────────────────────────────────────────────────
# Railway inyecta DATABASE_URL automáticamente al agregar el plugin MySQL.
# No es necesario definirla aquí; se lee en src/config/config.js (producción).
# DATABASE_URL=mysql://user:pass@host:port/dbname

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_este_secret_muy_seguro_en_produccion_min_32_chars
JWT_EXPIRES_IN=24h

# ── Uploads ────────────────────────────────────────────────────────────────────
# Dejar vacío para usar la ruta por defecto (server/uploads/solicitudes).
# En Railway con volumen persistente apuntar al mountpoint, p.ej.:
#   UPLOAD_PATH=/data/uploads/solicitudes
UPLOAD_PATH=
MAX_FILE_SIZE=10485760

# ── CORS ───────────────────────────────────────────────────────────────────────
# Separar múltiples orígenes con coma:
#   CORS_ORIGIN=https://mi-app.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ── Email (Nodemailer) ─────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=correo@istho.com.co
EMAIL_PASS=app_password_aqui
EMAIL_FROM="Soporte TI ISTHO <soporte@istho.com.co>"
