NODE_ENV=development
PORT=5000

# ── MySQL (desarrollo) ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=soporte_ti_istho
DB_USER=root
DB_PASSWORD=

# ── MySQL (producción) ─────────────────────────────────────────────────────────
# DATABASE_URL se provee automáticamente según la plataforma:
#   Railway  → plugin MySQL lo inyecta automáticamente
#   Render   → definir manualmente en el dashboard con el string de Aiven/TiDB
#   Aiven    → formato: mysql://user:pass@host:port/dbname?ssl-mode=REQUIRED
#   TiDB     → formato: mysql://user:pass@host:4000/dbname?ssl-mode=VERIFY_IDENTITY
# DATABASE_URL=mysql://user:pass@host:port/dbname

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_este_secret_muy_seguro_en_produccion_min_32_chars
JWT_EXPIRES_IN=24h

# ── Uploads ────────────────────────────────────────────────────────────────────
# Dejar vacío para usar la ruta por defecto (server/uploads/solicitudes).
# Con almacenamiento persistente apuntar al mountpoint, p.ej.:
#   Railway (Volume en /data): UPLOAD_PATH=/data/uploads/solicitudes
#   Render  (Disk en /data):   UPLOAD_PATH=/data/uploads/solicitudes
UPLOAD_PATH=
MAX_FILE_SIZE=10485760

# ── CORS ───────────────────────────────────────────────────────────────────────
# Separar múltiples orígenes con coma:
#   CORS_ORIGIN=https://mi-app.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ── Email (Nodemailer) ─────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=correo@istho.com.co
EMAIL_PASS=app_password_aqui
EMAIL_FROM="Soporte TI ISTHO <soporte@istho.com.co>"
